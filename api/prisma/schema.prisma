generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model customers {
  id        String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String @db.VarChar(255)
  email     String @db.VarChar(255)
  image_url String @db.VarChar(255)
}

model invoices {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  customer_id String   @db.Uuid
  amount      Int
  status      String   @db.VarChar(255)
  date        DateTime @db.Date
}

model revenue {
  month   String @unique @db.VarChar(4)
  revenue Int
}

model users {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name     String @db.VarChar(255)
  email    String @unique
  password String
}

enum InvoiceStatus {
  PENDING
  PAID
}

model im_Customer {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  invoices  im_Invoice[]
}

model im_Invoice {
  id          String        @id @default(uuid())
  customer_id String
  discount    Int
  tax         Int
  date        DateTime      @default(now())
  payment     im_Payment?
  status      InvoiceStatus
  customer    im_Customer      @relation(fields: [customer_id], references: [id])
  items       im_Item[]
}

model im_Payment {
  id          String        @id @default(uuid())
  invoice_id  String        @unique
  date        DateTime      @default(now())
  invoice     im_Invoice    @relation(fields: [invoice_id], references: [id])
}

model im_Item {
  id          String        @id @default(uuid())
  name        String
  price       Int
  invoice_id  String
  invoice     im_Invoice    @relation(fields: [invoice_id], references: [id])
}
